---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('projects', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long' });
---

<Layout title={entry.data.title} description={`${entry.data.title} — Your Name`}>
  <article class="page">

    <div class="page-header">
      <div class="proj-meta">
        <span>{entry.data.category}</span>
        <span aria-hidden="true">·</span>
        <time datetime={entry.data.date.toISOString()}>{fmt(entry.data.date)}</time>
      </div>
      <h1>{entry.data.title}</h1>
    </div>

    <div class="proj-cover">
      <img
        src={entry.data.cover}
        alt={entry.data.title}
        loading="eager"
        decoding="async"
      />
    </div>

    <div class="proj-body">
      <div class="prose">
        <Content />
      </div>
    </div>

    {entry.data.images.length > 0 && (
      <section class="gallery" aria-label="Images">
        <ul class="gal-grid" role="list">
          {entry.data.images.map((src, i) => (
            <li>
              <button
                class="gal-btn"
                data-src={src}
                data-alt={`${entry.data.title} — ${i + 1}`}
                aria-label={`Open image ${i + 1}`}
              >
                <img
                  src={src}
                  alt={`${entry.data.title} — ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                />
              </button>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="proj-back">
      <a href="/">← All work</a>
    </div>

  </article>

  <dialog id="lb" aria-label="Image viewer">
    <button id="lb-close" aria-label="Close">×</button>
    <img id="lb-img" src="" alt="" />
  </dialog>
</Layout>

<script>
  const lb = document.getElementById('lb') as HTMLDialogElement;
  const img = document.getElementById('lb-img') as HTMLImageElement;

  document.querySelectorAll<HTMLButtonElement>('.gal-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      img.src = btn.dataset.src ?? '';
      img.alt = btn.dataset.alt ?? '';
      lb.showModal();
    });
  });

  document.getElementById('lb-close')?.addEventListener('click', () => lb.close());
  lb.addEventListener('click', (e) => { if (e.target === lb) lb.close(); });
</script>

<style>
  .page {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--pad) 7rem;
    width: 100%;
  }

  /* ── Header ── */
  .page-header {
    padding: 3.5rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .proj-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.6rem;
    font-weight: 400;
  }

  .page-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  /* ── Cover ── */
  .proj-cover {
    margin-bottom: 3rem;
    overflow: hidden;
    background: var(--border);
  }

  .proj-cover img {
    width: 100%;
    max-height: 75vh;
    object-fit: cover;
    display: block;
  }

  /* ── Body ── */
  .proj-body { margin-bottom: 3.5rem; }

  .prose p {
    font-size: 0.9rem;
    line-height: 2;
    color: #444;
    font-weight: 300;
    margin-bottom: 1.1em;
    max-width: 580px;
  }

  /* ── Gallery ── */
  .gallery { margin-bottom: 4rem; }

  .gal-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
  }

  @media (max-width: 480px) {
    .gal-grid { grid-template-columns: 1fr; }
  }

  .gal-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: var(--border);
    cursor: zoom-in;
    overflow: hidden;
  }

  .gal-btn img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s;
    opacity: 0.95;
    display: block;
  }

  .gal-btn:hover img { transform: scale(1.04); opacity: 1; }

  /* ── Back ── */
  .proj-back { font-size: 0.72rem; letter-spacing: 0.06em; }

  .proj-back a {
    color: var(--muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .proj-back a:hover { color: var(--fg); border-color: var(--border); }

  /* ── Lightbox ── */
  #lb {
    border: none;
    padding: 0;
    background: #000;
    max-width: 95vw;
    max-height: 95vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lb::backdrop { background: rgba(0,0,0,0.92); }
  #lb[open] { display: flex; }

  #lb-img {
    display: block;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
  }

  #lb-close {
    position: fixed;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    z-index: 300;
    transition: color 0.2s;
    font-family: var(--f);
  }

  #lb-close:hover { color: #fff; }
</style>
