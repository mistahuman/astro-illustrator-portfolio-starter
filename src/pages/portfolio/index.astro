---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects', ({ data }) => !data.draft);
const projects = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

type Category = 'photo' | 'illustration' | 'design' | 'video' | 'other';
const categories: Category[] = ['photo', 'illustration', 'design', 'video', 'other'];
const labels: Record<string, string> = {
  photo: 'Photo',
  illustration: 'Illustration',
  design: 'Design',
  video: 'Video',
  other: 'Other',
};
---

<Layout title="Portfolio" description="Tutti i lavori — Elisa Lanconelli">
  <div class="portfolio-header">
    <h1>Enjoy my portfolio</h1>
    <div class="filters" id="filters" role="group" aria-label="Filtra per categoria">
      <button class="f-btn active" data-cat="">Tutti</button>
      {categories.map((c) => (
        <button class="f-btn" data-cat={c}>{labels[c]}</button>
      ))}
    </div>
  </div>

  <ul class="grid" role="list" id="grid">
    {projects.map((p) => (
      <li class="card" data-category={p.data.category}>
        <a href={`/portfolio/${p.data.slug}`}>
          <div class="card-img">
            <img
              src={p.data.cover}
              alt={p.data.title}
              loading="lazy"
              decoding="async"
            />
            <div class="card-over">
              <span class="card-name">{p.data.title}</span>
              <span class="card-cat">{p.data.category}</span>
            </div>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<script>
  const params = new URLSearchParams(location.search);
  let active = params.get('cat') ?? '';

  const btns = document.querySelectorAll<HTMLButtonElement>('.f-btn');
  const cards = document.querySelectorAll<HTMLLIElement>('.card');

  function apply(cat: string) {
    active = cat;
    btns.forEach((b) => b.classList.toggle('active', b.dataset.cat === cat));
    cards.forEach((c) => {
      (c as HTMLElement).hidden = !!(cat && c.dataset.category !== cat);
    });
    const u = new URL(location.href);
    cat ? u.searchParams.set('cat', cat) : u.searchParams.delete('cat');
    history.replaceState(null, '', u);
  }

  apply(active);
  btns.forEach((b) => b.addEventListener('click', () => apply(b.dataset.cat ?? '')));
</script>

<style>
  .portfolio-header {
    padding: 3.5rem 2rem 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .portfolio-header h1 {
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
  }

  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .f-btn {
    font-family: var(--f);
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.35rem 1rem;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }

  .f-btn:hover,
  .f-btn.active {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }

  /* Grid */
  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border);
  }

  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .grid { grid-template-columns: 1fr; } }

  .card { background: var(--bg); overflow: hidden; }
  .card[hidden] { display: none; }
  .card a { display: block; }

  .card-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card:hover .card-img img { transform: scale(1.06); }

  .card-over {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    opacity: 0;
    transition: opacity 0.35s;
    text-align: center;
    padding: 1.5rem;
  }

  .card:hover .card-over { opacity: 1; }

  .card-name {
    color: #fff;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .card-cat {
    color: rgba(255,255,255,0.65);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
