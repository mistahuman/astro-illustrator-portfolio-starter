---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects', ({ data }) => !data.draft);
const projects = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const base = import.meta.env.BASE_URL;

const COLORS = [
  '#D4826B', // terracotta
  '#6BA8C9', // dusty blue
  '#72B083', // sage green
  '#C9A44A', // amber
  '#9E72BB', // mauve
  '#4AABB5', // teal
];
---

<Layout title="Your Name" description="Illustrator based in Your City">
  <div class="page">

    <div class="page-header">
      <h1>Illustration</h1>
    </div>

    <ul class="grid" role="list">
      {projects.map((p, i) => (
        <li class="card" style={`--accent: ${COLORS[i % COLORS.length]}`}>
          <a href={`${base}portfolio/${p.data.slug}`} class="card-link" aria-label={p.data.title}>
            <div class="card-inner">

              <div class="card-front">
                <img
                  src={p.data.cover}
                  alt={p.data.title}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>

              <div class="card-back">
                <span class="back-cat">{p.data.category}</span>
                <span class="back-title">{p.data.title}</span>
                {p.data.excerpt && (
                  <span class="back-excerpt">{p.data.excerpt}</span>
                )}
                <span class="back-footer">
                  <span class="back-year">{p.data.date.getFullYear()}</span>
                  <span class="back-cta">View project →</span>
                </span>
              </div>

            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</Layout>

<style>
  .page {
    padding: 0 var(--pad) 6rem;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Header ── */
  .page-header {
    padding: 3.5rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Grid ── */
  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 820px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; gap: 1rem; }
  }

  /* ── Card shell ── */
  .card {
    border: 2.5px solid var(--accent);
    overflow: hidden;
  }

  .card-link {
    display: block;
    aspect-ratio: 4 / 5;
    perspective: 1100px;
    cursor: pointer;
  }

  /* ── Flip inner ── */
  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.62s cubic-bezier(0.4, 0.2, 0.2, 1);
  }

  .card:hover .card-inner {
    transform: rotateY(180deg);
  }

  /* ── Front ── */
  .card-front,
  .card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .card-front img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Back ── */
  .card-back {
    transform: rotateY(180deg);
    background: #111;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 1.5rem;
    gap: 0.4rem;
  }

  .back-cat {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 400;
    margin-bottom: 0.2rem;
  }

  .back-title {
    font-size: 1.05rem;
    font-weight: 400;
    color: #fff;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .back-excerpt {
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    line-height: 1.55;
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .back-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.12);
  }

  .back-year {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.06em;
  }

  .back-cta {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 400;
  }
</style>
